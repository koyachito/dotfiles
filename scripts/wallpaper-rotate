#!/usr/bin/env bash

# hyprpaperの壁紙を次の1枚に切り替えるスクリプト。
# systemd user timerから定期実行される想定。
# Hyprlandセッション外で起動された場合は何もせず正常終了する。

set -euo pipefail

# 対象の壁紙一覧（hyprpaper.confのpreloadと一致させること）
WALLPAPERS=(
	/usr/share/hypr/wall0.png
	/usr/share/hypr/wall1.png
	/usr/share/hypr/wall2.png
)

# --- Hyprlandインスタンスの検出 ---
# systemdから起動されるとHYPRLAND_INSTANCE_SIGNATUREが渡らず
# hyprctlが接続先を見つけられないため、ランタイムディレクトリから補完する。
if [[ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" ]]; then
	hypr_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hypr"
	# Hyprlandが動いていなければ静かに終了（インストール直後のTTY等）
	[[ -d "$hypr_dir" ]] || exit 0
	# 最終更新が最も新しいインスタンスディレクトリ名がシグネチャ。
	# ls の出力パースは SC2012 に反するため、bash の -nt（more recent than、
	# mtime 比較）でループして最新を選ぶ。外部コマンド不要でパースの問題もない。
	newest=""
	for d in "$hypr_dir"/*/; do
	# グロブが1件もマッチしないと "$hypr_dir/*/" が文字列のまま残るため実在確認で弾く
		[[ -e "$d" ]] || continue
		[[ -z "$newest" || "$d" -nt "$newest" ]] && newest="$d"
	done
	[[ -n "$newest" ]] || exit 0
	HYPRLAND_INSTANCE_SIGNATURE=$(basename "$newest")
	export HYPRLAND_INSTANCE_SIGNATURE
fi

# hyprpaperが未起動なら何もしない
pgrep -x hyprpaper > /dev/null || exit 0

# --- 現在の壁紙から次のインデックスを決める ---
# listactive の出力例: "eDP-1 = /usr/share/hyprland/wall0.png"
current=$(hyprctl hyprpaper listactive | head -n1 | awk -F' = ' '{print $2}')

next_index=0
for i in "${!WALLPAPERS[@]}"; do
	if [[ "${WALLPAPERS[$i]}" == "$current" ]]; then
		next_index=$(( (i + 1) % ${#WALLPAPERS[@]} ))
		break
	fi
done

# --- 切り替え（preload済みなので即時反映） ---
hyprctl hyprpaper wallpaper ", ${WALLPAPERS[$next_index]}"
