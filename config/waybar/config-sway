{
  "height": 30,
  "spacing": 4,

  "modules-left": [
    "sway/workspaces"
  ],

  "modules-center": [
    "sway/window"
  ],

  "sway/workspaces": {
  	"format": "{name}"
  },

  "sway/window": {
    "format": "{}",
    "max-length": 80
  },

  "modules-right": [
    "idle_inhibitor",
    "pulseaudio",
    "network",
    "cpu",
    "memory",
    "temperature",
    "backlight",
    "battery",
    "custom/world-clock",
    "tray"
  ],

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ",
      "deactivated": "ΎΒ░"
    }
  },

  "custom/world-clock": {
    "exec": "~/.config/waybar/scripts/world-clock.sh",
    "return-type": "json",
    "interval": 30
  },

  "cpu": {
    "format": "{usage}% ΎΜδ",
    "tooltip": false
  },

  "memory": {
    "format": "{}% ΎΔΚ"
  },

  "temperature": {
    "critical-threshold": 80,
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": [
      "≤░ΦΠ",
      "≤░ΦΡ",
      "≤▒ΔΓ"
    ]
  },

  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": [
      "ΌΟΞ",
      "ΌΠΥ",
      "ΌΠΣ",
      "ΌΠΠ",
      "ΌΠΟ",
      "ΌΠΞ",
      "ΌΠΛ",
      "ΌΠΙ",
      "ΌΟδ"
    ]
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ≤░ΓΕ",
    "format-plugged": "{capacity}% ΎΘο",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "≤░Β║",
      "≤░Β╗",
      "≤░Β╝",
      "≤░Β╜",
      "≤░Β╛",
      "≤░Β┐",
      "≤░ΓΑ",
      "≤░ΓΒ",
      "≤░ΓΓ",
      "≤░Β╣"
    ]
  },

  "network": {
    "format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
    "format-ethernet": "{ipaddr}/{cidr} ΎηΨ",
    "format-disconnected": "Disconnected έγι"
  },

  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-muted": "Ύγσ",
    "format-icons": {
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "ΎΑρ"
      ]
    },
    "on-click": "pavucontrol"
  },

  "tray": {
    "spacing": 10
  }
}
