#!/usr/bin/env bash

set -euo pipefail

echo "=== Checking for updates ==="
echo

# ---------- pacman ----------
echo "[pacman]"

PACMAN_OUTPUT="$(checkupdates 2>&1)" || PACMAN_STATUS=$?
PACMAN_STATUS=${PACMAN_STATUS:-0}

case "$PACMAN_STATUS" in
    0)
        echo "$PACMAN_OUTPUT"
        PACMAN_HAS_UPDATES=true
        ;;
    2)
        echo "No updates."
        PACMAN_HAS_UPDATES=false
        ;;
    *)
        echo "Failed to check updates:"
        echo "$PACMAN_OUTPUT"
        exit 1
        ;;
esac

echo

# ---------- cargo ----------
echo "[cargo]"

if CARGO_OUTPUT="$(cargo install-update -al 2>&1)"; then
    echo "$CARGO_OUTPUT"

    if grep -q "Yes" <<< "$CARGO_OUTPUT"; then
        CARGO_HAS_UPDATES=true
    else
        CARGO_HAS_UPDATES=false
    fi
else
    echo "Failed to check cargo updates:"
    echo "$CARGO_OUTPUT"
    exit 1
fi

echo

# ---------- no updates ----------
if ! $PACMAN_HAS_UPDATES && ! $CARGO_HAS_UPDATES; then
    echo "System is already up to date."
    exit 0
fi

read -rp "Continue with update? [y/N] " ans

if [[ ! "$ans" =~ ^[Yy]$ ]]; then
    echo "Canceled."
    exit 0
fi

echo
echo "Updating pacman..."
sudo pacman -Syu

echo
echo "Updating cargo..."
cargo install-update -a

echo
echo "Done!"
